# Database URL for PostgreSQL
DATABASE_URL=postgresql+asyncpg://username:password@ep-xxx-xxx.aws.neon.tech/dbname?sslmode=require

# Redis URL for caching (required for production)
REDIS_URL=redis://localhost:6379/0

# Alpha Vantage API Key
ALPHA_VANTAGE_API_KEY=tu_clave_api_alpha_vantage

# ExchangeRate-API Key
EXCHANGE_RATE_API_KEY=tu_clave_api_exchange_rate

# JWT Secret Key (Genera uno seguro con: openssl rand -hex 32)
SECRET_KEY=super_secret_key_change_in_production

# JWT Algorithm
ALGORITHM=HS256

# Access Token Expiration Time (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Environment: development, staging, production
ENVIRONMENT=development

# Server Host
HOST=0.0.0.0

# Server Port
PORT=8000

# Cache TTL in seconds (5 minutes)
CACHE_TTL_SECONDS=300

# Rate Limiting (requests per minute)
RATE_LIMIT_PER_MINUTE=60