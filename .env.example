# Database URL for PostgreSQL
DATABASE_URL=postgresql+asyncpg://username:password@host:5432/dbname

# Redis URL for caching (dejar vacío para fallback a PostgreSQL)
REDIS_URL=redis://localhost:6379/0

# Finnhub API Key (https://finnhub.io)
FINNHUB_API_KEY=tu_clave_api_finnhub

# ExchangeRate-API Key (https://exchangerate-api.com)
EXCHANGE_RATE_API_KEY=tu_clave_api_exchange_rate

# JWT Secret Key (Genera una con: openssl rand -hex 32)
SECRET_KEY=super_secret_key_change_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Entorno: development, staging, production
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8000

# Cache TTL en segundos (5 minutos)
CACHE_TTL_SECONDS=300

# Rate Limiting (peticiones por minuto)
RATE_LIMIT_PER_MINUTE=60

# --- Opcionales (pueden ir vacíos o con valores por defecto en local) ---

# Resend API Key para envío de correos (https://resend.com)
RESEND_API_KEY=

# Dirección from para correos
EMAIL_FROM=

# URL del frontend (para enlaces en correos)
FRONTEND_URL=http://localhost:5173

# Orígenes CORS permitidos (separados por coma)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# API Key para endpoints administrativos
ADMIN_API_KEY=

# Precargar stocks al iniciar la aplicación
ENABLE_STARTUP_PRELOAD=true
